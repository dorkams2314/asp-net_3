@model asp_net_3.Models.CartItem

@{
    ViewData["Title"] = "Удалить товар из корзины";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block">
    <h1 class="page-title">Удалить товар из корзины</h1>
    <p>Вы действительно хотите удалить эту запись?</p>

    @if (TempData["DeleteError"] != null) {
        <div class="alert alert-danger">@TempData["DeleteError"]</div>
    }

    <table class="simple-table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>@Model.Id</td>
            </tr>
            <tr>
                <th>CartId</th>
                <td>@Model.CartId</td>
            </tr>
            <tr>
                <th>Товар</th>
                <td>@Model.Product?.Name</td>
            </tr>
            <tr>
                <th>Количество</th>
                <td>@Model.Quantity</td>
            </tr>
        </tbody>
    </table>

    <form asp-action="Delete" method="post" class="mt-3">
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
    </form>
</div>
