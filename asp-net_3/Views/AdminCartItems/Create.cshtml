@model asp_net_3.Models.CartItem

@{
    ViewData["Title"] = "Добавить товар в корзину";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block form-block">
    <h1 class="page-title">Добавить товар в корзину</h1>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Корзина</label>
            <select asp-for="CartId" asp-items="ViewBag.Carts" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label class="form-label">Товар</label>
            <select asp-for="ProductId" asp-items="ViewBag.Products" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label class="form-label">Количество</label>
            <input asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
