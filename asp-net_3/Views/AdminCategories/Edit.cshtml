@model asp_net_3.Models.Category

@{
    ViewData["Title"] = "Изменить категорию";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block form-block">
    <h1 class="page-title">Изменить категорию</h1>

    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label class="form-label">Название</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
