@model IEnumerable<asp_net_3.Models.Product>

@{
    ViewData["Title"] = "Товары";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block">
    <div class="list-header">
        <h1 class="page-title">Товары</h1>
        <a class="btn btn-primary" asp-action="Create">Добавить товар</a>
    </div>

    <table class="simple-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Название</th>
                <th>Описание</th>
                <th>Цена</th>
                <th>Категория</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price.ToString("N2")</td>
                <td>@item.Category?.Name</td>
                <td class="simple-actions">
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
