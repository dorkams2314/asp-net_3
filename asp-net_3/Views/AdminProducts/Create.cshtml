@model asp_net_3.Models.Product

@{
    ViewData["Title"] = "Добавить товар";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block form-block">
    <h1 class="page-title">Добавить товар</h1>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="field-validation-error mb-3"></div>

        <div class="mb-3">
            <label class="form-label">Название</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Описание</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Цена</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Категория</label>
            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
