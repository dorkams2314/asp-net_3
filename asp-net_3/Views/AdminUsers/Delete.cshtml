@model asp_net_3.Models.User

@{
    ViewData["Title"] = "Удалить пользователя";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block">
    <h1 class="page-title">Удалить пользователя</h1>
    <p>Вы действительно хотите удалить эту запись?</p>

    @if (!ViewData.ModelState.IsValid) {
        <div asp-validation-summary="All" class="alert alert-danger"></div>
    }

    @if ((int?)ViewBag.CartCount > 0 || (int?)ViewBag.OrderCount > 0) {
        <div class="alert alert-warning">
            У пользователя есть связанные записи: корзин - @ViewBag.CartCount, заказов - @ViewBag.OrderCount.
            Корзины будут удалены автоматически, а при наличии заказов удаление пользователя недоступно.
        </div>
    }

    <table class="simple-table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>@Model.Id</td>
            </tr>
            <tr>
                <th>Логин</th>
                <td>@Model.Login</td>
            </tr>
            <tr>
                <th>Пароль</th>
                <td>@Model.PasswordHash</td>
            </tr>
            <tr>
                <th>Роль</th>
                <td>@Model.Role?.Name</td>
            </tr>
        </tbody>
    </table>

    <form asp-action="Delete" method="post" class="mt-3">
        <input asp-for="Id" type="hidden" />
        <button type="submit" class="btn btn-danger">Удалить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Отмена</a>
    </form>
</div>
