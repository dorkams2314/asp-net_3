@model IEnumerable<asp_net_3.Models.User>

@{
    ViewData["Title"] = "Пользователи";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block">
    <div class="list-header">
        <h1 class="page-title">Пользователи</h1>
        <a class="btn btn-primary" asp-action="Create">Добавить пользователя</a>
    </div>

    <table class="simple-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Логин</th>
                <th>Пароль</th>
                <th>Роль</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Id</td>
                <td>@item.Login</td>
                <td>@item.PasswordHash</td>
                <td>@item.Role?.Name</td>
                <td class="simple-actions">
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
