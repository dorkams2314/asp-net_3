@model asp_net_3.Models.User

@{
    ViewData["Title"] = "Добавить пользователя";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block form-block">
    <h1 class="page-title">Добавить пользователя</h1>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Логин</label>
            <input asp-for="Login" class="form-control" />
            <span asp-validation-for="Login" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Пароль</label>
            <input asp-for="PasswordHash" class="form-control" />
            <span asp-validation-for="PasswordHash" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Роль</label>
            <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-select"></select>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
