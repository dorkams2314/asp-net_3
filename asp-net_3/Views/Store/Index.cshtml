@model IEnumerable<asp_net_3.Models.Product>

@{
    ViewData["Title"] = "Каталог товаров";
}

<div class="page-block">
    <h1 class="page-title">Каталог товаров</h1>
    <p class="page-text">На странице выводятся товары из базы данных с названием, описанием, категорией и ценой.</p>
</div>

@if (TempData["Message"] != null) {
    <div class="alert alert-success">@TempData["Message"]</div>
}

<div class="page-block">
    <table class="simple-table">
        <thead>
            <tr>
                <th>Название</th>
                <th>Категория</th>
                <th>Описание</th>
                <th>Цена</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var product in Model) {
            <tr>
                <td>@product.Name</td>
                <td>@product.Category?.Name</td>
                <td>@product.Description</td>
                <td class="price-cell">@product.Price.ToString("N2") руб.</td>
                <td>
                    <div class="simple-actions">
                        <a class="btn btn-outline-secondary btn-sm" asp-controller="Store" asp-action="Details" asp-route-id="@product.Id">Подробнее</a>
                        <form asp-controller="Cart" asp-action="Add" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">В корзину</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
