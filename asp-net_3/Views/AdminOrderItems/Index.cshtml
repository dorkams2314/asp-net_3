@model IEnumerable<asp_net_3.Models.OrderItem>

@{
    ViewData["Title"] = "Состав заказа";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block">
    <div class="list-header">
        <h1 class="page-title">Состав заказа</h1>
        <a class="btn btn-primary" asp-action="Create">Добавить запись</a>
    </div>

    <table class="simple-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>OrderId</th>
                <th>ProductId</th>
                <th>Товар</th>
                <th>Количество</th>
                <th>Цена</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@item.Id</td>
                <td>@item.OrderId</td>
                <td>@item.ProductId</td>
                <td>@item.Product?.Name</td>
                <td>@item.Quantity</td>
                <td>@item.Price.ToString("N2")</td>
                <td class="simple-actions">
                    <a class="btn btn-outline-secondary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Изменить</a>
                    <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Удалить</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
