@model asp_net_3.Models.OrderItem

@{
    ViewData["Title"] = "Добавить запись в состав заказа";
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block form-block">
    <h1 class="page-title">Добавить запись в состав заказа</h1>

    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Заказ</label>
            <select asp-for="OrderId" asp-items="ViewBag.Orders" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label class="form-label">Товар</label>
            <select asp-for="ProductId" asp-items="ViewBag.Products" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label class="form-label">Количество</label>
            <input asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Цена</label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
