@model asp_net_3.Models.Order

@{
    ViewData["Title"] = "Изменить заказ";
    var dateValue = Model.OrderDate.ToString("yyyy-MM-ddTHH:mm");
}

@await Html.PartialAsync("_AdminMenu")

<div class="page-block form-block">
    <h1 class="page-title">Изменить заказ</h1>

    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />

        <div class="mb-3">
            <label class="form-label">Пользователь</label>
            <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select"></select>
        </div>

        <div class="mb-3">
            <label class="form-label">Дата заказа</label>
            <input asp-for="OrderDate" class="form-control" type="datetime-local" value="@dateValue" />
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </form>
</div>
